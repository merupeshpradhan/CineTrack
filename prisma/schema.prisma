generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  otp       String?
  otpExpiry DateTime?

  movies    Movie[]

  createdAt DateTime @default(now())
}

model Movie {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String
  description String
  watchDate   DateTime
  watched     Boolean @default(false)

  userId String
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}